# 复制本文件为 .env，填入真实值（.env 已被 .gitignore 排除，不会上传）

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-key-here

# Phase 2 Embedding 配置
# 可选值：
#   ollama      本地 Ollama，适合个人电脑本地运行
#   siliconflow 硅基流动 SiliconFlow，适合没有本地 Ollama 的同学跨平台验证
EMBEDDING_PROVIDER=ollama

# 当 EMBEDDING_PROVIDER=ollama 时使用
OLLAMA_EMBEDDING_MODEL=bge-m3

# 当 EMBEDDING_PROVIDER=siliconflow 时使用
# 切换到 SiliconFlow 后，建议删除 chroma_db/ 或重新 build_index，保证索引和查询使用同一套 embedding。
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# Neo4j 连接（可选，不用 Neo4j 时留空）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
